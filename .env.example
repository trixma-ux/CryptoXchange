# =============================================
# CryptoXchange — Variables d'Environnement
# =============================================
# Copiez ce fichier en .env et configurez les valeurs

# ---- Application ----
NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:3000
APP_NAME=CryptoXchange

# ---- Base de données PostgreSQL ----
DATABASE_URL=postgresql://cryptouser:cryptopassword123@localhost:5432/cryptoxchange

# ---- Redis (Sessions, Cache, Rate Limiting) ----
REDIS_URL=redis://localhost:6379

# ---- JWT Tokens ----
JWT_SECRET=your_super_secret_jwt_key_min_64_chars_change_in_production
JWT_REFRESH_SECRET=your_refresh_token_secret_min_64_chars_change_in_production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ---- Email (SMTP) ----
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM=noreply@cryptoxchange.com

# ---- SMS (Twilio) ----
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_PHONE_NUMBER=+1234567890

# ---- 2FA (TOTP) ----
TOTP_ISSUER=CryptoXchange

# ---- CoinGecko API (Prix crypto) ----
COINGECKO_API_KEY=your_coingecko_api_key

# ---- Paiements Mobile Money ----
# Orange Money
ORANGE_MONEY_CLIENT_ID=your_orange_client_id
ORANGE_MONEY_CLIENT_SECRET=your_orange_client_secret
ORANGE_MONEY_BASE_URL=https://api.orange.com/orange-money-webpay/dev/v1

# MTN Mobile Money
MTN_MOMO_API_KEY=your_mtn_api_key
MTN_MOMO_SUBSCRIPTION_KEY=your_mtn_subscription_key
MTN_MOMO_BASE_URL=https://sandbox.momodeveloper.mtn.com

# Wave
WAVE_API_KEY=your_wave_api_key
WAVE_BASE_URL=https://api.wave.com/v1

# ---- Upload Fichiers (KYC) ----
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# ---- Sécurité ----
BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
LOGIN_ATTEMPTS_MAX=5
LOGIN_LOCKOUT_DURATION=1800000

# ---- Frais par défaut (en %) ----
DEFAULT_TRADING_FEE=0.1
DEFAULT_WITHDRAWAL_FEE=0.5
DEFAULT_SWAP_FEE=0.2
DEFAULT_DEPOSIT_FEE=0

# ---- Devise locale par défaut ----
DEFAULT_FIAT_CURRENCY=XOF
DEFAULT_FIAT_SYMBOL=FCFA
